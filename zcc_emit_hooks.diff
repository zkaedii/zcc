SECTION 6 — Branch / if / loop (ND_IF, ND_FOR, ND_WHILE)
═══════════════════════════════════════════════════════════════

ND_IF typically emits a je/jne pair to a label counter.
Mirror the label counter into IR:

    case ND_IF: {
        int c = count();   /* ZCC's internal label counter */
+       char _ir_lbl_else[IR_LABEL_MAX], _ir_lbl_end[IR_LABEL_MAX];
+       char _ir_cond[IR_NAME_MAX];
+       /* Mirror the same counter into IR labels */
+       if (g_emit_ir) {
+           snprintf(_ir_lbl_else, IR_LABEL_MAX, ".Lir_else_%d", c);
+           snprintf(_ir_lbl_end,  IR_LABEL_MAX, ".Lir_end_%d",  c);
+       }
        gen_expr(node->cond);
+       if (g_emit_ir) {
+           ir_fresh_tmp(g_ir_cur_func, _ir_cond);
+           ZCC_EMIT_BR_IF(_ir_cond, _ir_lbl_else, node->tok->line);
+       }
        fprintf(output, "    cmpq $0, %%rax\n");
        fprintf(output, "    je  .L.else.%d\n", c);
        gen_stmt(node->then);
        ...
        /* at the else label: */
        fprintf(output, ".L.else.%d:\n", c);
+       if (g_emit_ir) ZCC_EMIT_LABEL(_ir_lbl_else, node->tok->line);
        ...
    }

