--- a/zcc.c  (after post-mortem P1-IR integration)
+++ b/zcc.c  (with per-instruction emit hooks wired)

CONTEXT: codegen_func() already has ZCC_IR_FUNC_BEGIN/END.
         This diff wires ZCC_EMIT_* at each x86 emit site
         so IR nodes are actually populated.

All changes are ADDITIVE — the x86 fprintf paths are untouched.
stage2 == stage3 must still pass after this patch.

═══════════════════════════════════════════════════════════════
SECTION 1 — Binary arithmetic (ADD, SUB, MUL, DIV, MOD)
═══════════════════════════════════════════════════════════════

Find the block that emits x86 addq/subq/imulq for ND_ADD/ND_SUB/ND_MUL.
It will look something like:

    case ND_ADD:
        gen_expr(node->lhs);
        gen_expr(node->rhs);
        fprintf(output, "    popq %%rdi\n");
        fprintf(output, "    addq %%rdi, %%rax\n");
        break;

Patch each case:

    case ND_ADD: {
+       char _ir_dst[IR_NAME_MAX], _ir_s1[IR_NAME_MAX], _ir_s2[IR_NAME_MAX];
+       ir_type_t _ir_ty = zcc_type_to_ir(node->ty->kind);
        gen_expr(node->lhs);
+       if (g_emit_ir) ir_fresh_tmp(g_ir_cur_func, _ir_s1);
        gen_expr(node->rhs);
+       if (g_emit_ir) ir_fresh_tmp(g_ir_cur_func, _ir_s2);
        fprintf(output, "    popq %%rdi\n");
        fprintf(output, "    addq %%rdi, %%rax\n");
+       if (g_emit_ir) {
+           ir_fresh_tmp(g_ir_cur_func, _ir_dst);
+           ZCC_EMIT_BINARY(IR_ADD, _ir_ty, _ir_dst, _ir_s1, _ir_s2, node->tok->line);
+       }
        break;
    }

Apply the same pattern for:
    ND_SUB  → ZCC_EMIT_BINARY(IR_SUB, ...)
    ND_MUL  → ZCC_EMIT_BINARY(IR_MUL, ...)
    ND_DIV  → ZCC_EMIT_BINARY(IR_DIV, ...)
    ND_MOD  → ZCC_EMIT_BINARY(IR_MOD, ...)
    ND_NEG  → ZCC_EMIT_UNARY(IR_NEG, ...)

