NEW HELPER — safe_ir_name()  (add near top of zcc.c, after includes)
═══════════════════════════════════════════════════════════════

/* Sanitize a C variable name for use as an IR temp name.
 * IR_NAME_MAX = 64.  Replaces characters illegal in IR names with '_'. */
static void safe_ir_name(char *buf, const char *cname) {
    int i = 0;
    if (!cname) { buf[0] = '\0'; return; }
    while (i < IR_NAME_MAX - 1 && cname[i]) {
        char c = cname[i];
        buf[i] = (c == '.' || c == '-' || c == '$') ? '_' : c;
        i++;
    }
    buf[i] = '\0';
}

