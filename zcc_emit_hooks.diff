═══════════════════════════════════════════════════════════════
SECTION 3 — Variable load / store (ND_VAR, ND_ASSIGN)
═══════════════════════════════════════════════════════════════

Variable read (lvalue → rvalue load):

    case ND_VAR:
        gen_addr(node);
        load(node->ty);
        break;

Patch:

    case ND_VAR: {
+       char _ir_dst[IR_NAME_MAX], _ir_addr[IR_NAME_MAX];
        gen_addr(node);
+       if (g_emit_ir && node->var) {
+           /* addr temp: use the variable's own name as the address ref */
+           safe_ir_name(_ir_addr, node->var->name);
+           ir_fresh_tmp(g_ir_cur_func, _ir_dst);
+           ZCC_EMIT_LOAD(zcc_type_to_ir(node->ty->kind), _ir_dst, _ir_addr,
+                         node->tok->line);
+       }
        load(node->ty);
        break;
    }

Assignment (ND_ASSIGN):

    case ND_ASSIGN:
        gen_addr(node->lhs);
        gen_expr(node->rhs);
        store(node->ty);
        break;

Patch:

    case ND_ASSIGN: {
+       char _ir_addr[IR_NAME_MAX], _ir_val[IR_NAME_MAX];
        gen_addr(node->lhs);
+       if (g_emit_ir && node->lhs->var) {
+           safe_ir_name(_ir_addr, node->lhs->var->name);
+           ir_fresh_tmp(g_ir_cur_func, _ir_val);
+       }
        gen_expr(node->rhs);
        store(node->ty);
+       if (g_emit_ir && node->lhs->var) {
+           ZCC_EMIT_STORE(zcc_type_to_ir(node->ty->kind), _ir_addr, _ir_val,
+                          node->tok->line);
+       }
        break;
    }

