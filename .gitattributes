# Normalize line endings for text files going forward.
# Existing CRLF files stay as they are until rewritten.
# Added Apr 25 2026 alongside Systems Graveyard milestone.

* text=auto

# Source code: enforce LF
*.c       text eol=lf
*.h       text eol=lf
*.py      text eol=lf
*.sh      text eol=lf
*.md      text eol=lf
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.ipynb   text eol=lf
*.jsonl   text eol=lf
Makefile  text eol=lf

# Binary file types — never normalize
*.ppm     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.glb     binary
*.gltf    binary
*.mp3     binary
*.mp4     binary
*.wav     binary
*.zip     binary
*.tar.gz  binary
*.pdf     binary
*.gguf    binary
*.pt      binary
*.npz     binary
