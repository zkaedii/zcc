# --- Compiled binaries & objects ---
*.o
*.exe
*.so
*.out
*.prof
*.dump
*.objdump

# --- Assembly output (build artifacts) ---
*.s
# Keep shell scripts
!*.sh

# --- ELF/firmware binaries ---
*.elf
*.bin
*.uf2

# --- Named compiler binaries ---
zcc1
zcc2
zcc2_*
zcc3
zcc3_*
zcc_no_peep
zcc_peep

# --- Test binaries (extensionless) ---
